<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">
    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Custom Commands"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="16dp"/>
    
    <Spinner
        android:id="@+id/templateSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"/>
    
    <EditText
        android:id="@+id/commandInput"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:hint="TRIGGER: vid&#10;NAME: Quick Video&#10;ACTION: RECORD_VIDEO duration=2"/>
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        
        <Button
            android:id="@+id/parseButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Add Command"
            android:backgroundTint="#4CAF50"
            android:layout_marginEnd="8dp"/>
        
        <Button
            android:id="@+id/helpButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Help"
            android:backgroundTint="#2196F3"/>
    </LinearLayout>
    
    <TextView
        android:id="@+id/previewText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:textSize="11sp"
        android:fontFamily="monospace"/>
    
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/commandsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"/>
    
</LinearLayout>
